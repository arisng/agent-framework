@* DataGridDisplay: Renders tabular data from the show_data_grid tool as a styled table *@

@using AGUIDojoClient.Models
@using BlazorBlueprint.Components.Badge
@using BlazorBlueprint.Icons.Lucide.Components

<div class="data-grid-display">
    @if (!string.IsNullOrWhiteSpace(DataGrid.Title))
    {
        <div class="data-grid-header">
            <LucideIcon Name="table" Size="16" Class="data-grid-icon" />
            <span class="data-grid-title">@DataGrid.Title</span>
            <Badge Variant="BadgeVariant.Secondary" Class="data-grid-count">
                @DataGrid.Rows.Count @(DataGrid.Rows.Count == 1 ? "row" : "rows")
            </Badge>
        </div>
    }

    <div class="data-grid-table-container">
        <table class="data-grid-table">
            <thead>
                <tr>
                    @foreach (var column in DataGrid.Columns)
                    {
                        <th>@column</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (DataGrid.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="@DataGrid.Columns.Count" class="data-grid-empty">
                            No data available.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var row in DataGrid.Rows)
                    {
                        <tr>
                            @foreach (var column in DataGrid.Columns)
                            {
                                <td>
                                    @if (row.TryGetValue(column, out var value))
                                    {
                                        @RenderCellValue(column, value)
                                    }
                                    else
                                    {
                                        <span class="data-grid-null">—</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    /// <summary>
    /// The data grid result to display.
    /// </summary>
    [Parameter, EditorRequired]
    public required DataGridResult DataGrid { get; set; }

    /// <summary>
    /// Renders a cell value, applying special formatting for known patterns like status badges.
    /// </summary>
    private static RenderFragment RenderCellValue(string column, string value)
    {
        // Render status-like values as badges
        if (column.Equals("Status", StringComparison.OrdinalIgnoreCase))
        {
            return builder =>
            {
                var variant = value.ToLowerInvariant() switch
                {
                    "shipped" or "delivered" or "completed" or "active" => BadgeVariant.Default,
                    "processing" or "in progress" => BadgeVariant.Secondary,
                    "pending" or "draft" => BadgeVariant.Outline,
                    "cancelled" or "failed" or "rejected" => BadgeVariant.Destructive,
                    _ => BadgeVariant.Secondary
                };

                builder.OpenComponent<Badge>(0);
                builder.AddAttribute(1, "Variant", variant);
                builder.AddAttribute(2, "ChildContent", (RenderFragment)(b => b.AddContent(0, value)));
                builder.CloseComponent();
            };
        }

        // Default: plain text
        return builder => builder.AddContent(0, value);
    }
}
