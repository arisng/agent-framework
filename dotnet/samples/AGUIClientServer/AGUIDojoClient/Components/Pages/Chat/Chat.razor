@page "/"
@using AGUIDojoClient.Helpers
@using AGUIDojoClient.Store.AgentState
@using AGUIDojoClient.Store.ArtifactState
@using AGUIDojoClient.Store.ChatState
@using AGUIDojoClient.Store.PlanState
@inject IAGUIChatClientFactory ClientFactory
@inject IAgentStreamingService StreamingService
@inject IObservabilityService ObservabilityService
@inject IRiskAssessmentService RiskAssessmentService
@inject ICheckpointService CheckpointService
@inject IStateManager StateManager
@inject ViewportService ViewportService
@inject IDispatcher Dispatcher
@inject IState<PlanState> PlanStore
@inject IState<AgentState> AgentStore
@inject IState<ArtifactState> ArtifactStore
@inject IState<ChatState> ChatStore
@implements IDisposable

<PageTitle>AG-UI Dojo Chat</PageTitle>

<ChatHeader OnNewChat="@ResetConversationAsync"
            AvailableEndpoints="@ClientFactory.AvailableEndpoints"
            SelectedEndpointPath="@AgentStore.Value.SelectedEndpointPath"
            OnEndpointChanged="@OnEndpointChangedAsync" />

@* MY CUSTOMIZATION POINT: PanicButton — emergency stop visible during agent execution *@
<div class="panic-button-container">
    <PanicButton IsAgentRunning="@AgentStore.Value.IsRunning"
                 OnPanic="@HandlePanicAsync" />
</div>

@* MY CUSTOMIZATION POINT: Dual-pane layout — chat in Context Pane (left), artifacts in Canvas Pane (right) *@
<DualPaneLayout>
    <ContextPaneContent>
        <ContextPane>
            <ChatMessageList Messages="@ChatStore.Value.Messages" InProgressMessage="@ChatStore.Value.CurrentResponseMessage">
                <NoMessagesContent>
                    <div>Ask the assistant a question to start a conversation.</div>
                </NoMessagesContent>
            </ChatMessageList>
            <div class="chat-container">
                <ChatSuggestions OnSelected="@AddUserMessageAsync" @ref="@chatSuggestions" />
                <ChatInput OnSend="@AddUserMessageAsync" @ref="@chatInput" />
            </div>

            @* MY CUSTOMIZATION POINT: Conditional approval UI — SwipeApproval on mobile, ApprovalQueue on desktop *@
            @if (ChatStore.Value.PendingApproval is not null)
            {
                @if (ViewportService.IsMobile)
                {
                    <SwipeApproval FunctionName="@ChatStore.Value.PendingApproval.FunctionName"
                                   Arguments="@ChatHelpers.ConvertApprovalArguments(ChatStore.Value.PendingApproval.FunctionArguments)"
                                   RiskLevel="@RiskAssessmentService.AssessRisk(ChatStore.Value.PendingApproval.FunctionName)"
                                   OnDecision="@OnApprovalDecision" />
                }
                else
                {
                    <ApprovalQueue FunctionName="@ChatStore.Value.PendingApproval.FunctionName"
                                   Arguments="@ChatHelpers.ConvertApprovalArguments(ChatStore.Value.PendingApproval.FunctionArguments)"
                                   RiskLevel="@RiskAssessmentService.AssessRisk(ChatStore.Value.PendingApproval.FunctionName)"
                                   OnDecision="@OnApprovalDecision" />
                }
            }
        </ContextPane>
    </ContextPaneContent>
    <CanvasPaneContent>
        <CanvasPane>
            @* MY CUSTOMIZATION POINT: Observability components displayed in Canvas Pane *@
            <MemoryInspector ConversationId="@ChatStore.Value.ConversationId"
                             SelectedEndpoint="@AgentStore.Value.SelectedEndpointPath"
                             MessageCount="@ChatStore.Value.Messages.Count"
                             PlanStepCount="@(PlanStore.Value.Plan?.Steps?.Count)"
                             PlanCompletedCount="@(PlanStore.Value.Plan?.Steps?.Count(s => s.Status == StepStatus.Completed))"
                             RecipeName="@(IsSharedStateEndpoint ? ArtifactStore.Value.CurrentRecipe?.Title : null)"
                             DocumentLength="@(IsPredictiveStateEndpoint ? ArtifactStore.Value.CurrentDocumentState?.Document?.Length : null)"
                             ToolInvocations="@StreamingService.GetToolInvocationSummary()" />

            <ToolExecutionTracker Steps="@ObservabilityService.GetSteps()" />

            @* MY CUSTOMIZATION POINT: Governance components displayed in Canvas Pane *@
            <CheckpointManager Checkpoints="@CheckpointService.GetAllCheckpoints()"
                               OnRevert="@HandleCheckpointRevertAsync" />

            @if (StreamingService.LastDiffBefore is not null || StreamingService.LastDiffAfter is not null)
            {
                <DiffPreview Before="@StreamingService.LastDiffBefore" After="@StreamingService.LastDiffAfter" Title="@StreamingService.LastDiffTitle" />
            }

            @* MY CUSTOMIZATION POINT: Artifact components (RecipeEditor, DocumentPreview) are now
               rendered by CanvasPane directly from IState<ArtifactState> — see CanvasPane.razor *@
        </CanvasPane>
    </CanvasPaneContent>
</DualPaneLayout>

@code {
    private const string SystemPrompt = @"
        You are a helpful assistant.
        ";

    private const int ThrottleDelayMs = 100; // Throttle StateHasChanged to prevent render thrashing

    private ChatInput? chatInput;
    private ChatSuggestions? chatSuggestions;
    private IChatClient? activeChatClient;
    private DateTime lastStateChangeTime = DateTime.MinValue;
    private bool pendingStateChange = false;
    private System.Timers.Timer? throttleTimer;

    /// <summary>
    /// Gets whether the currently selected endpoint is the Shared State endpoint.
    /// </summary>
    private bool IsSharedStateEndpoint => AgentStore.Value.SelectedEndpointPath.Equals("shared_state", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Gets whether the currently selected endpoint is the Predictive State Updates endpoint.
    /// </summary>
    private bool IsPredictiveStateEndpoint => AgentStore.Value.SelectedEndpointPath.Equals("predictive_state_updates", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        Dispatcher.Dispatch(new ChatActions.AddMessageAction(new(ChatRole.System, SystemPrompt)));
        activeChatClient = ClientFactory.CreateClient(AgentStore.Value.SelectedEndpointPath);

        // Register UI callbacks for the streaming service
        StreamingService.SetUiCallbacks(ThrottledStateHasChanged, () => InvokeAsync(StateHasChanged));

        // Initialize state manager for Shared State feature
        StreamingService.InitializeEndpointState(AgentStore.Value.SelectedEndpointPath);

        // Initialize throttle timer for debounced UI updates
        throttleTimer = new System.Timers.Timer(ThrottleDelayMs);
        throttleTimer.AutoReset = false;
        throttleTimer.Elapsed += OnThrottleElapsed;

        // Subscribe to Fluxor state changes with throttled rendering
        // (NOT FluxorComponent — preserves ThrottledStateHasChanged for SSE streaming)
        PlanStore.StateChanged += OnFluxorStateChanged;
        AgentStore.StateChanged += OnFluxorStateChanged;
        ArtifactStore.StateChanged += OnFluxorStateChanged;
        ChatStore.StateChanged += OnFluxorStateChanged;
    }

    /// <summary>
    /// Handles Fluxor state changes by triggering throttled UI updates.
    /// Uses a single handler for all stores instead of FluxorComponent
    /// to preserve ThrottledStateHasChanged debounce for SSE streaming.
    /// </summary>
    private void OnFluxorStateChanged(object? sender, EventArgs e) => ThrottledStateHasChanged();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ViewportService.InitializeAsync();
            ViewportService.OnViewportChanged += OnViewportChanged;
        }
    }

    private void OnViewportChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

    /// <summary>
    /// Throttled StateHasChanged to prevent render thrashing during rapid streaming updates.
    /// </summary>
    private void ThrottledStateHasChanged()
    {
        DateTime now = DateTime.UtcNow;
        if ((now - lastStateChangeTime).TotalMilliseconds >= ThrottleDelayMs)
        {
            lastStateChangeTime = now;
            InvokeAsync(StateHasChanged);
        }
        else
        {
            pendingStateChange = true;
            throttleTimer?.Stop();
            throttleTimer?.Start();
        }
    }

    private void OnThrottleElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        if (pendingStateChange)
        {
            pendingStateChange = false;
            lastStateChangeTime = DateTime.UtcNow;
            InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Handles endpoint selection change by creating a new client and resetting the conversation.
    /// </summary>
    private async Task OnEndpointChangedAsync(string newEndpointPath)
    {
        if (string.Equals(AgentStore.Value.SelectedEndpointPath, newEndpointPath, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        Dispatcher.Dispatch(new AgentActions.SetEndpointAction(newEndpointPath));
        activeChatClient = ClientFactory.CreateClient(newEndpointPath);
        await ResetConversationAsync();
        StreamingService.InitializeEndpointState(newEndpointPath);
    }

    private async Task AddUserMessageAsync(ChatMessage userMessage)
    {
        StreamingService.CancelAnyCurrentResponse();

        // For shared state endpoint, add state DataContent to the user message
        if (IsSharedStateEndpoint && StateManager.HasActiveState)
        {
            DataContent stateContent = StateManager.CreateStateContent();
            userMessage.Contents.Add(stateContent);
        }

        Dispatcher.Dispatch(new ChatActions.AddMessageAction(userMessage));
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();

        await StreamingService.ProcessAgentResponseAsync(activeChatClient!);
        chatSuggestions?.Update(ChatStore.Value.Messages);
    }

    /// <summary>
    /// Handles the user's approval/rejection decision from the approval UI.
    /// Delegates to <see cref="IAgentStreamingService.ResolveApproval"/> to unblock the streaming loop.
    /// </summary>
    private void OnApprovalDecision(bool approved) => StreamingService.ResolveApproval(approved);

    /// <summary>
    /// Handles the emergency stop action. Delegates to the streaming service
    /// and refocuses the chat input.
    /// </summary>
    private async Task HandlePanicAsync()
    {
        StreamingService.HandlePanic(AgentStore.Value.SelectedEndpointPath);
        await chatInput!.FocusAsync();
    }

    /// <summary>
    /// Handles reverting to a specific checkpoint from the CheckpointManager timeline.
    /// Delegates to the streaming service and refocuses the chat input.
    /// </summary>
    private async Task HandleCheckpointRevertAsync(string checkpointId)
    {
        StreamingService.HandleCheckpointRevert(checkpointId, AgentStore.Value.SelectedEndpointPath);
        await chatInput!.FocusAsync();
    }

    private async Task ResetConversationAsync()
    {
        StreamingService.ResetConversation(SystemPrompt, AgentStore.Value.SelectedEndpointPath);
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();
    }

    public void Dispose()
    {
        ViewportService.OnViewportChanged -= OnViewportChanged;
        PlanStore.StateChanged -= OnFluxorStateChanged;
        AgentStore.StateChanged -= OnFluxorStateChanged;
        ArtifactStore.StateChanged -= OnFluxorStateChanged;
        ChatStore.StateChanged -= OnFluxorStateChanged;
        throttleTimer?.Stop();
        throttleTimer?.Dispose();
    }
}
