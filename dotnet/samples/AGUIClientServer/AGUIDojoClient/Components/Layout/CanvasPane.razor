@* MY CUSTOMIZATION POINT: CanvasPane wrapper component for dual-pane artifact/work product area *@
@using BlazorBlueprint.Components.ScrollArea
@using BlazorBlueprint.Components.Card
@using BlazorBlueprint.Components.Button
@using BlazorBlueprint.Components.Progress
@using BlazorBlueprint.Icons.Lucide.Components
@using AGUIDojoClient.Models
@using AGUIDojoClient.Store.AgentState
@using AGUIDojoClient.Store.ArtifactState
@using AGUIDojoClient.Store.PlanState
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IState<PlanState> PlanStore
@inject IState<ArtifactState> ArtifactStore
@inject IState<AgentState> AgentStore
@inject IStateManager StateManager
@inject IDispatcher Dispatcher

<div class="canvas-pane">
    @* MY CUSTOMIZATION POINT: Compact plan indicator — shown when an active plan exists.
       Displays progress bar + "View Plan" button that opens the PlanSheet overlay. *@
    @if (PlanStore.Value.Plan is not null)
    {
        <div class="canvas-pane__plan-indicator">
            <div class="canvas-pane__plan-info">
                <LucideIcon Name="clipboard-list" Size="16" />
                <span class="canvas-pane__plan-label">Plan</span>
                <span class="canvas-pane__plan-count">@CompletedCount / @PlanStore.Value.Plan.Steps.Count</span>
            </div>
            <Progress Value="@ProgressPercent" Class="canvas-pane__plan-progress" />
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="@OpenPlanSheet" Class="canvas-pane__plan-btn">
                <LucideIcon Name="panel-right-open" Size="14" />
                View Plan
            </Button>
        </div>
    }

    <ScrollArea Class="canvas-pane__scroll">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @* MY CUSTOMIZATION POINT: Empty state using BlazorBlueprint Card *@
            <div class="canvas-pane__empty-state">
                <Card Class="canvas-pane__empty-card">
                    <CardContent Class="canvas-pane__empty-content">
                        <LucideIcon Name="layout-dashboard" Size="48" Class="canvas-pane__empty-icon" />
                        <p class="canvas-pane__empty-title">No active artifacts</p>
                        <p class="canvas-pane__empty-description">
                            Artifacts such as plans, documents, and shared state will appear here
                            when generated by the agent.
                        </p>
                    </CardContent>
                </Card>
            </div>
        }

        @* MY CUSTOMIZATION POINT: Artifact components rendered from Fluxor ArtifactState store *@

        @* Show Recipe Editor when using the Shared State endpoint *@
        @if (IsSharedStateEndpoint)
        {
            <RecipeEditor Recipe="@(ArtifactStore.Value.CurrentRecipe ?? StateManager.CurrentRecipe ?? new Recipe())"
                          RecipeChanged="@OnRecipeChanged" />
        }

        @* Show Document Preview when using the Predictive State Updates endpoint.
           When diff data is available (previous version exists), renders a Monaco diff editor
           for side-by-side comparison; falls back to DocumentPreview otherwise. *@
        @if (IsPredictiveStateEndpoint && ArtifactStore.Value.CurrentDocumentState is not null)
        {
            @if (HasDiffData && !_monacoInitFailed)
            {
                <div class="canvas-pane__monaco-container">
                    <div class="canvas-pane__monaco-header">
                        <LucideIcon Name="git-compare-arrows" Size="16" />
                        <span class="canvas-pane__monaco-title">Document Changes</span>
                        @if (ArtifactStore.Value.IsDocumentPreview)
                        {
                            <span class="canvas-pane__monaco-badge streaming">Streaming...</span>
                        }
                        else
                        {
                            <span class="canvas-pane__monaco-badge finalized">Review</span>
                        }
                    </div>
                    <div class="canvas-pane__monaco-editor">
                        <MonacoEditor EditorId="canvas-diff-editor"
                                      OriginalText="@(_previousDocumentText ?? string.Empty)"
                                      ModifiedText="@(ArtifactStore.Value.CurrentDocumentState.Document ?? string.Empty)"
                                      Language="markdown"
                                      OriginalReadOnly="true"
                                      ModifiedReadOnly="false" />
                    </div>
                </div>
            }
            else
            {
                <DocumentPreview DocumentState="@ArtifactStore.Value.CurrentDocumentState"
                                 IsPreview="@ArtifactStore.Value.IsDocumentPreview"
                                 Title="Document Preview" />
            }
        }
    </ScrollArea>
</div>

@* MY CUSTOMIZATION POINT: PlanSheet — slides in from right to show full plan progress *@
<PlanSheet @bind-IsOpen="_showPlanSheet" />

@code {
    /// <summary>
    /// Optional content to render in the canvas pane. When null, an empty state message is displayed.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Whether the PlanSheet overlay is currently open.
    /// </summary>
    private bool _showPlanSheet;

    /// <summary>
    /// Tracks the previous finalized document text for the Monaco diff editor's "Original" pane.
    /// Set when the document transitions from preview (streaming) to finalized.
    /// </summary>
    private string? _previousDocumentText;

    /// <summary>
    /// Tracks whether the last observed <see cref="ArtifactState.IsDocumentPreview"/> value was <c>true</c>.
    /// Used to detect finalization transitions (preview → finalized).
    /// </summary>
    private bool _lastKnownIsPreview;

    /// <summary>
    /// Falls back to <see cref="DocumentPreview"/> when the Monaco editor fails to initialize
    /// (e.g., JS interop unavailable or circuit disconnected).
    /// </summary>
    private bool _monacoInitFailed;

    /// <summary>
    /// Gets whether diff data is available for the Monaco diff editor.
    /// True when a previous finalized document version exists and differs from the current version.
    /// </summary>
    private bool HasDiffData =>
        _previousDocumentText is not null
        && ArtifactStore.Value.CurrentDocumentState?.Document is not null
        && !string.Equals(_previousDocumentText, ArtifactStore.Value.CurrentDocumentState.Document, StringComparison.Ordinal);

    /// <summary>
    /// Gets whether the currently selected endpoint is the Shared State endpoint.
    /// </summary>
    private bool IsSharedStateEndpoint => AgentStore.Value.SelectedEndpointPath.Equals("shared_state", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Gets whether the currently selected endpoint is the Predictive State Updates endpoint.
    /// </summary>
    private bool IsPredictiveStateEndpoint => AgentStore.Value.SelectedEndpointPath.Equals("predictive_state_updates", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Gets the count of completed steps in the current plan.
    /// </summary>
    private int CompletedCount => PlanStore.Value.Plan?.Steps.Count(s => s.Status == StepStatus.Completed) ?? 0;

    /// <summary>
    /// Gets the progress percentage (0–100) for the compact progress bar.
    /// </summary>
    private int ProgressPercent => PlanStore.Value.Plan?.Steps.Count > 0
        ? (int)((double)CompletedCount / PlanStore.Value.Plan.Steps.Count * 100)
        : 0;

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        TrackDocumentTransitions();
    }

    /// <summary>
    /// Tracks document state transitions to capture the previous finalized version
    /// for use as the Monaco diff editor's "Original" pane.
    /// </summary>
    private void TrackDocumentTransitions()
    {
        var currentDoc = ArtifactStore.Value.CurrentDocumentState?.Document;
        var isPreview = ArtifactStore.Value.IsDocumentPreview;

        // Document transitioned from preview → finalized: save as previous for next diff cycle
        if (_lastKnownIsPreview && !isPreview && currentDoc is not null)
        {
            _previousDocumentText = currentDoc;
        }

        // Artifacts cleared (new conversation or endpoint switch): reset previous
        if (ArtifactStore.Value.CurrentDocumentState is null && _previousDocumentText is not null)
        {
            _previousDocumentText = null;
            _monacoInitFailed = false;
        }

        _lastKnownIsPreview = isPreview;
    }

    /// <summary>
    /// Opens the PlanSheet overlay to display the full plan progress.
    /// </summary>
    private void OpenPlanSheet()
    {
        _showPlanSheet = true;
    }

    /// <summary>
    /// Handles recipe changes from the RecipeEditor component.
    /// Updates both the StateManager (for state content creation) and the Fluxor ArtifactState store.
    /// </summary>
    private void OnRecipeChanged(Recipe recipe)
    {
        StateManager.UpdateRecipe(recipe);
        Dispatcher.Dispatch(new SetRecipeAction(recipe));
    }
}
