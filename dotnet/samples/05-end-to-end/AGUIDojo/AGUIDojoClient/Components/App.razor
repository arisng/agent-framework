<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    @* FOUC prevention: read localStorage theme before first paint to avoid flash *@
    <script>
        (function() {
            var theme = localStorage.getItem('theme');
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>

    <link rel="stylesheet" href="app.css" />
    @* BlazorBlueprint CSS (shadcn/ui-based component library) *@
    <link rel="stylesheet" href="_content/BlazorBlueprint.Components/blazorblueprint.css" />
    <link rel="stylesheet" href="AGUIDojoClient.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="@renderMode" />
</head>

<body>
    <Routes @rendermode="@renderMode" />

    @* BlazorMonaco scripts — must load before blazor.web.js *@
    <script src="_content/BlazorMonaco/jsInterop.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/loader.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/editor/editor.main.js"></script>

    @* Theme interop module for dark/light switching via localStorage *@
    <script src="js/theme.js"></script>

    @* Command Palette interop for global Ctrl+K / Cmd+K keyboard shortcut *@
    <script src="js/commandPalette.js"></script>

    @* Session persistence interop for localStorage + IndexedDB storage *@
    <script src="js/sessionPersistence.js"></script>

    <script src="_framework/blazor.web.js"></script>
</body>

</html>

@code {
    private readonly IComponentRenderMode renderMode = new InteractiveServerRenderMode(prerender: false);
}
