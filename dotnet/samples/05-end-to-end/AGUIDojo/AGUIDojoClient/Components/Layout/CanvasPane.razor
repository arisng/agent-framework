@* CanvasPane wrapper component for dual-pane artifact/work product area.
   Uses BB Tabs (controlled mode) bound to the active session state for dynamic tabbed artifact display. *@
@using AGUIDojoClient.Models
@using AGUIDojoClient.Store.SessionManager
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IState<SessionManagerState> SessionStore
@inject IStateManager StateManager
@inject IDispatcher Dispatcher

<div class="canvas-pane">
    @* Compact plan indicator — shown when an active plan exists.
       Displays progress bar + "View Plan" button that opens the PlanSheet overlay. *@
    @if (ActiveSession.Plan is not null)
    {
        <div class="canvas-pane__plan-indicator">
            <div class="canvas-pane__plan-info">
                <LucideIcon Name="clipboard-list" Size="16" />
                <span class="canvas-pane__plan-label">Plan</span>
                <span class="canvas-pane__plan-count">@CompletedCount / @ActiveSession.Plan.Steps.Count</span>
            </div>
            <BbProgress Value="@ProgressPercent" Class="canvas-pane__plan-progress" />
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="@OpenPlanSheet" Class="canvas-pane__plan-btn">
                <LucideIcon Name="panel-right-open" Size="14" />
                View Plan
            </BbButton>
        </div>
    }

    @* Tabbed artifact display using BB Tabs (controlled mode).
       Tabs are dynamically shown/hidden based on the active session state.
       ActiveArtifactType drives which tab is selected; auto-switches when new artifacts arrive. *@
    @if (ActiveSession.VisibleTabs.Count == 0 && ChildContent is null)
    {
        @* Empty state — no artifacts yet *@
        <div class="canvas-pane__scroll">
            <div class="canvas-pane__empty-state">
                <BbCard Class="canvas-pane__empty-card">
                    <BbCardContent Class="canvas-pane__empty-content">
                        <LucideIcon Name="layout-dashboard" Size="48" Class="canvas-pane__empty-icon" />
                        <p class="canvas-pane__empty-title">No active artifacts</p>
                        <p class="canvas-pane__empty-description">
                            Artifacts such as plans, documents, and shared state will appear here
                            when generated by the agent.
                        </p>
                    </BbCardContent>
                </BbCard>
            </div>
        </div>
    }
    else
    {
        <BbTabs Value="@ActiveTabValue" ValueChanged="@OnTabChanged" Class="canvas-pane__tabs">
            <BbTabsList Class="canvas-pane__tabs-list">
                @if (ChildContent is not null)
                {
                    <BbTabsTrigger Value="child-content" Class="canvas-pane__tab-trigger">
                        <LucideIcon Name="file-text" Size="14" />
                        <span>Content</span>
                    </BbTabsTrigger>
                }
                @foreach (var tab in ActiveSession.VisibleTabs)
                {
                    <BbTabsTrigger Value="@tab.ToString()" Class="canvas-pane__tab-trigger">
                        <LucideIcon Name="@GetTabIcon(tab)" Size="14" />
                        <span>@GetTabLabel(tab)</span>
                    </BbTabsTrigger>
                }
            </BbTabsList>

            @* Child content tab (legacy pass-through) *@
            @if (ChildContent is not null)
            {
                <BbTabsContent Value="child-content" ForceMount="true" Class="canvas-pane__tab-content">
                    <div class="canvas-pane__scroll">
                        @ChildContent
                    </div>
                </BbTabsContent>
            }

            @* DiffPreview tab — shown when diff preview data exists *@
            @if (ActiveSession.VisibleTabs.Contains(ArtifactType.DiffPreview))
            {
                <BbTabsContent Value="@nameof(ArtifactType.DiffPreview)" ForceMount="true" Class="canvas-pane__tab-content">
                    <div class="canvas-pane__scroll">
                        @if (ActiveSession.DiffPreview is not null)
                        {
                            <DiffPreview Before="@ActiveSession.DiffPreview.Before"
                                         After="@ActiveSession.DiffPreview.After"
                                         Title="@ActiveSession.DiffPreview.Title" />
                        }
                    </div>
                </BbTabsContent>
            }

            @* DataGrid tab — BB DataTable with search, sort, pagination, column visibility.
               No canvas-pane__scroll wrapper: DataGrid manages its own internal scroll
               so pagination stays fixed at the bottom of the tab. *@
            @if (ActiveSession.VisibleTabs.Contains(ArtifactType.DataGrid))
            {
                <BbTabsContent Value="@nameof(ArtifactType.DataGrid)" ForceMount="true" Class="canvas-pane__tab-content">
                    @if (ActiveSession.CurrentDataGrid is not null)
                    {
                        <DataGridDisplay DataGrid="@ActiveSession.CurrentDataGrid" />
                    }
                </BbTabsContent>
            }

            @* RecipeEditor tab — shared state endpoint *@
            @if (ActiveSession.VisibleTabs.Contains(ArtifactType.RecipeEditor))
            {
                <BbTabsContent Value="@nameof(ArtifactType.RecipeEditor)" ForceMount="true" Class="canvas-pane__tab-content">
                    <div class="canvas-pane__scroll">
                        <RecipeEditor Recipe="@(ActiveSession.CurrentRecipe ?? StateManager.CurrentRecipe ?? new Recipe())"
                                      RecipeChanged="@OnRecipeChanged" />
                    </div>
                </BbTabsContent>
            }

            @* DocumentPreview tab — predictive state updates endpoint *@
            @if (ActiveSession.VisibleTabs.Contains(ArtifactType.DocumentPreview))
            {
                <BbTabsContent Value="@nameof(ArtifactType.DocumentPreview)" ForceMount="true" Class="canvas-pane__tab-content">
                    <div class="canvas-pane__scroll">
                        @if (ActiveSession.CurrentDocumentState is not null)
                        {
                            @if (HasDiffData && !_monacoInitFailed)
                            {
                                <div class="canvas-pane__monaco-container">
                                    <div class="canvas-pane__monaco-header">
                                        <LucideIcon Name="git-compare-arrows" Size="16" />
                                        <span class="canvas-pane__monaco-title">Document Changes</span>
                                        @if (ActiveSession.IsDocumentPreview)
                                        {
                                            <BbBadge Variant="BadgeVariant.Secondary" Class="canvas-pane__monaco-badge streaming">Streaming...</BbBadge>
                                        }
                                        else
                                        {
                                            <BbBadge Variant="BadgeVariant.Outline" Class="canvas-pane__monaco-badge finalized">Review</BbBadge>
                                        }
                                    </div>
                                    <div class="canvas-pane__monaco-editor">
                                        <MonacoEditor EditorId="canvas-diff-editor"
                                                      OriginalText="@(_previousDocumentText ?? string.Empty)"
                                                      ModifiedText="@(ActiveSession.CurrentDocumentState.Document ?? string.Empty)"
                                                      Language="markdown"
                                                      OriginalReadOnly="true"
                                                      ModifiedReadOnly="false" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <DocumentPreview DocumentState="@ActiveSession.CurrentDocumentState"
                                                 IsPreview="@ActiveSession.IsDocumentPreview"
                                                 Title="Document Preview" />
                            }
                        }
                    </div>
                </BbTabsContent>
            }

            @* AuditTrail tab — timeline of tool call approval decisions *@
            @if (ActiveSession.VisibleTabs.Contains(ArtifactType.AuditTrail))
            {
                <BbTabsContent Value="@nameof(ArtifactType.AuditTrail)" ForceMount="true" Class="canvas-pane__tab-content">
                    <div class="canvas-pane__scroll">
                        <AuditTrailPanel Entries="@ActiveSession.AuditTrail" />
                    </div>
                </BbTabsContent>
            }
        </BbTabs>
    }
</div>

@* PlanSheet — slides in from right to show full plan progress *@
<PlanSheet @bind-IsOpen="_showPlanSheet" />

@code {
    /// <summary>
    /// Optional content to render in the canvas pane. When null, an empty state message is displayed.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Whether the PlanSheet overlay is currently open.
    /// </summary>
    private bool _showPlanSheet;

    /// <summary>
    /// Tracks the previous finalized document text for the Monaco diff editor's "Original" pane.
    /// Set when the document transitions from preview (streaming) to finalized.
    /// </summary>
    private string? _previousDocumentText;

    /// <summary>
    /// Tracks whether the last observed document preview value was <c>true</c>.
    /// Used to detect finalization transitions (preview → finalized).
    /// </summary>
    private bool _lastKnownIsPreview;

    /// <summary>
    /// Falls back to <see cref="DocumentPreview"/> when the Monaco editor fails to initialize
    /// (e.g., JS interop unavailable or circuit disconnected).
    /// </summary>
    private bool _monacoInitFailed;

    /// <summary>
    /// Gets the active tab value as a string for BB Tabs controlled mode.
    /// Maps the Fluxor <see cref="ArtifactType"/> enum to the string tab value.
    /// Falls back to "child-content" when ChildContent is present but no artifact tab is active.
    /// </summary>
    private string ActiveTabValue
    {
        get
        {
            var activeType = ActiveSession.ActiveArtifactType;
            if (activeType != ArtifactType.None)
            {
                return activeType.ToString();
            }

            // Fallback: if we have ChildContent but no active artifact, select it
            if (ChildContent is not null)
            {
                return "child-content";
            }

            // Fallback: select first visible tab
            return ActiveSession.VisibleTabs.Count > 0
                ? ActiveSession.VisibleTabs.First().ToString()
                : string.Empty;
        }
    }

    /// <summary>
    /// Gets whether diff data is available for the Monaco diff editor.
    /// True when a previous finalized document version exists and differs from the current version.
    /// </summary>
    private bool HasDiffData =>
        _previousDocumentText is not null
        && ActiveSession.CurrentDocumentState?.Document is not null
        && !string.Equals(_previousDocumentText, ActiveSession.CurrentDocumentState.Document, StringComparison.Ordinal);

    /// <summary>
    /// Gets the count of completed steps in the current plan.
    /// </summary>
    private SessionState ActiveSession => SessionSelectors.GetActiveState(SessionStore.Value);

    private string ActiveSessionId => SessionSelectors.GetActiveMetadata(SessionStore.Value).Id;

    private int CompletedCount => ActiveSession.Plan?.Steps.Count(s => s.Status == StepStatus.Completed) ?? 0;

    /// <summary>
    /// Gets the progress percentage (0–100) for the compact progress bar.
    /// </summary>
    private int ProgressPercent => ActiveSession.Plan?.Steps.Count > 0
        ? (int)((double)CompletedCount / ActiveSession.Plan.Steps.Count * 100)
        : 0;

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        TrackDocumentTransitions();
    }

    /// <summary>
    /// Handles BB Tabs ValueChanged event. Dispatches <see cref="SessionActions.SetActiveArtifactAction"/>
    /// to update session state when the user switches tabs.
    /// </summary>
    private void OnTabChanged(string? newValue)
    {
        if (string.IsNullOrEmpty(newValue) || newValue == "child-content")
        {
            Dispatcher.Dispatch(new SessionActions.SetActiveArtifactAction(ActiveSessionId, ArtifactType.None));
            return;
        }

        if (Enum.TryParse<ArtifactType>(newValue, out var artifactType))
        {
            Dispatcher.Dispatch(new SessionActions.SetActiveArtifactAction(ActiveSessionId, artifactType));
        }
    }

    /// <summary>
    /// Returns the Lucide icon name for a given artifact type tab.
    /// </summary>
    private static string GetTabIcon(ArtifactType type) => type switch
    {
        ArtifactType.DiffPreview => "git-compare-arrows",
        ArtifactType.DataGrid => "table-2",
        ArtifactType.RecipeEditor => "chef-hat",
        ArtifactType.DocumentPreview => "file-text",
        ArtifactType.AuditTrail => "scroll-text",
        _ => "file"
    };

    /// <summary>
    /// Returns the display label for a given artifact type tab.
    /// </summary>
    private static string GetTabLabel(ArtifactType type) => type switch
    {
        ArtifactType.DiffPreview => "Diff Preview",
        ArtifactType.DataGrid => "Data Table",
        ArtifactType.RecipeEditor => "Recipe Editor",
        ArtifactType.DocumentPreview => "Document",
        ArtifactType.AuditTrail => "Audit Trail",
        _ => type.ToString()
    };

    /// <summary>
    /// Tracks document state transitions to capture the previous finalized version
    /// for use as the Monaco diff editor's "Original" pane.
    /// </summary>
    private void TrackDocumentTransitions()
    {
        var currentDoc = ActiveSession.CurrentDocumentState?.Document;
        var isPreview = ActiveSession.IsDocumentPreview;

        // Document transitioned from preview → finalized: save as previous for next diff cycle
        if (_lastKnownIsPreview && !isPreview && currentDoc is not null)
        {
            _previousDocumentText = currentDoc;
        }

        // Artifacts cleared (new conversation or endpoint switch): reset previous
        if (ActiveSession.CurrentDocumentState is null && _previousDocumentText is not null)
        {
            _previousDocumentText = null;
            _monacoInitFailed = false;
        }

        _lastKnownIsPreview = isPreview;
    }

    /// <summary>
    /// Opens the PlanSheet overlay to display the full plan progress.
    /// </summary>
    private void OpenPlanSheet()
    {
        _showPlanSheet = true;
    }

    /// <summary>
    /// Handles recipe changes from the RecipeEditor component.
    /// Updates both the StateManager (for state content creation) and the active session store.
    /// </summary>
    private void OnRecipeChanged(Recipe recipe)
    {
        StateManager.UpdateRecipe(recipe);
        Dispatcher.Dispatch(new SessionActions.SetRecipeAction(ActiveSessionId, recipe));
    }
}
