@* PlanSheet — right-side Sheet overlay for full plan progress display.
   Reads plan state from the active session and renders the PlanProgress component
   inside a BlazorBlueprint Sheet. Opened via the "View Plan" button in CanvasPane. *@

@using AGUIDojoClient.Models
@using AGUIDojoClient.Store.SessionManager
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IState<SessionManagerState> SessionStore

<BbSheet Open="IsOpen" OpenChanged="OnOpenChanged">
    <BbSheetContent Side="BlazorBlueprint.Primitives.SheetSide.Right" Class="plan-sheet">
        <BbSheetHeader>
            <BbSheetTitle>
                <div class="plan-sheet__title-row">
                    <LucideIcon Name="clipboard-list" Size="20" />
                    <span>Execution Plan</span>
                    @if (ActivePlan is not null)
                    {
                        <BbBadge Variant="BadgeVariant.Secondary" Class="plan-sheet__badge">
                            @CompletedCount / @ActivePlan.Steps.Count
                        </BbBadge>
                    }
                </div>
            </BbSheetTitle>
            <BbSheetDescription>
                View and track the agent's execution plan progress.
            </BbSheetDescription>
        </BbSheetHeader>

        <div class="plan-sheet__body">
            @if (ActivePlan is not null)
            {
                <PlanProgress />
            }
            else
            {
                <div class="plan-sheet__empty">
                    <LucideIcon Name="clipboard" Size="40" Class="plan-sheet__empty-icon" />
                    <p class="plan-sheet__empty-title">No active plan</p>
                    <p class="plan-sheet__empty-description">
                        A plan will appear here when the agent creates one during execution.
                    </p>
                </div>
            }
        </div>

        <BbSheetFooter>
            <BbSheetClose>Close</BbSheetClose>
        </BbSheetFooter>
    </BbSheetContent>
</BbSheet>

@code {
    /// <summary>
    /// Whether the sheet is currently open. Two-way bound to the parent component
    /// via <c>@bind-IsOpen</c> so the parent can open/close the sheet programmatically.
    /// </summary>
    [Parameter]
    public bool IsOpen { get; set; }

    /// <summary>
    /// Callback invoked when <see cref="IsOpen"/> changes, enabling two-way binding
    /// from the parent component (e.g., <c>&lt;PlanSheet @bind-IsOpen="_showPlanSheet" /&gt;</c>).
    /// </summary>
    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    /// <summary>
    /// Gets the count of completed steps in the current plan.
    /// </summary>
    private Plan? ActivePlan => SessionSelectors.GetActiveState(SessionStore.Value).Plan;

    private int CompletedCount => ActivePlan?.Steps.Count(s => s.Status == StepStatus.Completed) ?? 0;

    /// <summary>
    /// Handles the Sheet's Open state change and notifies the parent via two-way binding.
    /// </summary>
    private async Task OnOpenChanged(bool value)
    {
        IsOpen = value;
        await IsOpenChanged.InvokeAsync(value);
    }
}
