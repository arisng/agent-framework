@* Command Palette — global Ctrl+K / Cmd+K quick-action dialog.
   Uses BlazorBlueprint Dialog + Command components to list registered tools and
   current session actions. Keyboard shortcut is handled via JS interop in
   commandPalette.js which invokes the TogglePalette callback. *@

@using AGUIDojoClient.Models
@using AGUIDojoClient.Services
@using AGUIDojoClient.Store.SessionManager
@inject IToolComponentRegistry ToolRegistry
@inject IDispatcher Dispatcher
@inject IState<SessionManagerState> SessionStore
@inject IThemeService ThemeService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<BbDialog @bind-Open="_isOpen">
    <BbDialogContent Class="p-0 max-w-lg">
        <BbCommand>
            <BbCommandInput Placeholder="Type a command or search..." />
            <BbCommandList>
                <BbCommandEmpty>No results found.</BbCommandEmpty>

                <BbCommandGroup Heading="Sessions">
                    @foreach (SessionEntry session in OrderedSessions)
                    {
                        <BbCommandItem Value="@session.Metadata.Id"
                                       SearchText="@($"{session.Metadata.Title} {session.Metadata.Id}")"
                                       OnSelect="@(() => ActivateSessionAsync(session.Metadata.Id))">
                            <LucideIcon Name="message-circle" Size="16" />
                            @session.Metadata.Title
                        </BbCommandItem>
                    }
                </BbCommandGroup>

                <BbCommandSeparator />

                <BbCommandGroup Heading="Available Tools">
                    @foreach (string tool in ToolRegistry.RegisteredTools)
                    {
                        <BbCommandItem Value="@tool"
                                       SearchText="@tool"
                                       OnSelect="@ClosePaletteAsync">
                            <LucideIcon Name="wrench" Size="16" />
                            @tool
                        </BbCommandItem>
                    }
                </BbCommandGroup>

                <BbCommandSeparator />

                <BbCommandGroup Heading="Actions">
                    <BbCommandItem Value="new-chat" OnSelect="@CreateNewChatAsync">
                        <LucideIcon Name="plus" Size="16" />
                        New Chat
                    </BbCommandItem>
                    <BbCommandItem Value="toggle-theme" OnSelect="@ToggleThemeAsync">
                        <LucideIcon Name="sun" Size="16" />
                        Toggle Theme
                    </BbCommandItem>
                    <BbCommandItem Value="toggle-sidebar" OnSelect="@ToggleSidebarAsync">
                        <LucideIcon Name="panel-right-close" Size="16" />
                        Toggle Sidebar
                    </BbCommandItem>
                </BbCommandGroup>
            </BbCommandList>
        </BbCommand>
    </BbDialogContent>
</BbDialog>

@code {
    /// <summary>
    /// Whether the command palette dialog is currently open.
    /// Bound to <c>Dialog.Open</c> for two-way state synchronization.
    /// </summary>
    private bool _isOpen;

    /// <summary>
    /// .NET object reference passed to JS for the keyboard shortcut callback.
    /// Disposed on component teardown.
    /// </summary>
    private DotNetObjectReference<CommandPalette>? _dotNetRef;

    private IReadOnlyList<SessionEntry> OrderedSessions => SessionSelectors.GetOrderedSessions(SessionStore.Value);

    /// <summary>
    /// Registers the global Ctrl+K / Cmd+K keyboard shortcut via JS interop
    /// after the first render when the Blazor circuit is established.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                await JSRuntime.InvokeVoidAsync("commandPaletteInterop.register", _dotNetRef);
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected — safe to ignore during disposal/navigation
            }
        }
    }

    /// <summary>
    /// Invoked from JavaScript when the user presses Ctrl+K or Cmd+K.
    /// Toggles the command palette dialog open/closed state.
    /// </summary>
    [JSInvokable]
    public void TogglePalette()
    {
        _isOpen = !_isOpen;
        StateHasChanged();
    }

    private Task ClosePaletteAsync()
    {
        _isOpen = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ActivateSessionAsync(string sessionId)
    {
        Dispatcher.Dispatch(new SessionActions.SetActiveSessionAction(sessionId));
        await ClosePaletteAsync();
    }

    private async Task CreateNewChatAsync()
    {
        string sessionId = Guid.NewGuid().ToString("N");
        Dispatcher.Dispatch(new SessionActions.CreateSessionAction(sessionId, EndpointPath: SessionMetadata.DefaultEndpointPath));
        await ClosePaletteAsync();
    }

    private async Task ToggleThemeAsync()
    {
        await ThemeService.ToggleThemeAsync();
        await ClosePaletteAsync();
    }

    private async Task ToggleSidebarAsync()
    {
        await JSRuntime.InvokeVoidAsync("commandPaletteInterop.toggleSidebar");
        await ClosePaletteAsync();
    }

    /// <summary>
    /// Unregisters the global keyboard listener and disposes the .NET object
    /// reference to prevent memory leaks and stale callbacks.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commandPaletteInterop.unregister");
        }
        catch (JSDisconnectedException)
        {
            // Circuit already disconnected — safe to ignore
        }

        _dotNetRef?.Dispose();
    }
}
