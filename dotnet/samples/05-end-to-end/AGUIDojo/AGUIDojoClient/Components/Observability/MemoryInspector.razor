<BbCard Class="memory-inspector">
    <BbCardHeader>
        <BbCardTitle>
            <LucideIcon Name="brain" Size="16" />
            Agent Context
        </BbCardTitle>
        <BbCardDescription>Active session state and memory</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        @* Session Info Section *@
        <div class="memory-section">
            <div class="memory-section-title">Session</div>
            <div class="memory-item">
                <span class="memory-label">Conversation</span>
                <BbBadge Variant="BadgeVariant.Outline">@(ConversationId ?? "N/A")</BbBadge>
            </div>
            <div class="memory-item">
                <span class="memory-label">Route</span>
                <BbBadge Variant="BadgeVariant.Secondary">@(SessionRoute ?? "N/A")</BbBadge>
            </div>
            <div class="memory-item">
                <span class="memory-label">Messages</span>
                <BbBadge>@MessageCount</BbBadge>
            </div>
        </div>

        <BbSeparator />

        @* Active State Objects Section *@
        <div class="memory-section">
            <div class="memory-section-title">State</div>
            @if (PlanStepCount.HasValue)
            {
                <div class="memory-item">
                    <span class="memory-label">Plan Steps</span>
                    <BbBadge Variant="BadgeVariant.Secondary">@PlanStepCount.Value total</BbBadge>
                    @if (PlanCompletedCount.HasValue)
                    {
                        <BbBadge>@PlanCompletedCount.Value done</BbBadge>
                    }
                </div>
            }
            @if (RecipeName is not null)
            {
                <div class="memory-item">
                    <span class="memory-label">Recipe</span>
                    <BbBadge Variant="BadgeVariant.Secondary">@RecipeName</BbBadge>
                </div>
            }
            @if (DocumentLength.HasValue)
            {
                <div class="memory-item">
                    <span class="memory-label">Document</span>
                    <BbBadge Variant="BadgeVariant.Secondary">@DocumentLength.Value chars</BbBadge>
                </div>
            }
            @if (!PlanStepCount.HasValue && RecipeName is null && !DocumentLength.HasValue)
            {
                <div class="memory-item">
                    <span class="memory-label">No active state</span>
                    <BbBadge Variant="BadgeVariant.Outline">N/A</BbBadge>
                </div>
            }
        </div>

        <BbSeparator />

        @* Tool Invocation Summary Section *@
        <div class="memory-section">
            <div class="memory-section-title">Tools</div>
            @if (ToolInvocations is not null && ToolInvocations.Count > 0)
            {
                @foreach (var tool in ToolInvocations)
                {
                    <div class="memory-item">
                        <span class="memory-label">@tool.Key</span>
                        <BbBadge>@tool.Value</BbBadge>
                    </div>
                }
            }
            else
            {
                <div class="memory-item">
                    <span class="memory-label">No tools called</span>
                    <BbBadge Variant="BadgeVariant.Outline">N/A</BbBadge>
                </div>
            }
        </div>
    </BbCardContent>
</BbCard>

@code {
    /// <summary>
    /// The current conversation ID, if active.
    /// </summary>
    [Parameter]
    public string? ConversationId { get; set; }

    /// <summary>
    /// The current AG-UI route for the active session.
    /// </summary>
    [Parameter]
    public string? SessionRoute { get; set; }

    /// <summary>
    /// The total number of messages in the conversation.
    /// </summary>
    [Parameter]
    public int MessageCount { get; set; }

    /// <summary>
    /// The total number of steps in the current plan, if any.
    /// </summary>
    [Parameter]
    public int? PlanStepCount { get; set; }

    /// <summary>
    /// The number of completed plan steps, if a plan is active.
    /// </summary>
    [Parameter]
    public int? PlanCompletedCount { get; set; }

    /// <summary>
    /// The name of the active recipe, if the session currently has recipe state.
    /// </summary>
    [Parameter]
    public string? RecipeName { get; set; }

    /// <summary>
    /// The character length of the current document, if a document preview is active.
    /// </summary>
    [Parameter]
    public int? DocumentLength { get; set; }

    /// <summary>
    /// A dictionary mapping tool names to their invocation counts.
    /// </summary>
    [Parameter]
    public IReadOnlyDictionary<string, int>? ToolInvocations { get; set; }
}
