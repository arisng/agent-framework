@using AGUIDojoClient.Models
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="mermaid-display">
    <div class="mermaid-display__header">
        <div class="mermaid-display__title-row">
            <LucideIcon Name="workflow" Size="16" Class="mermaid-display__icon" />
            <span class="mermaid-display__title">@Diagram.Title</span>
            <BbBadge Variant="BadgeVariant.Outline" Class="mermaid-display__badge">Mermaid</BbBadge>
        </div>

        @if (!string.IsNullOrWhiteSpace(Diagram.Description))
        {
            <p class="mermaid-display__description">@Diagram.Description</p>
        }
    </div>

    <div class="mermaid-display__surface">
        @if (_renderFailed)
        {
            <div class="mermaid-display__fallback">
                <p class="mermaid-display__fallback-copy">Interactive rendering is unavailable, so the Mermaid source is shown below.</p>
                <pre class="mermaid-display__source">@Diagram.Definition</pre>
            </div>
        }
        else
        {
            <div class="mermaid-display__canvas" @ref="_canvas"></div>
        }
    </div>
</div>

@code {
    private ElementReference _canvas;
    private IJSObjectReference? _module;
    private bool _renderFailed;
    private string? _lastRenderedDefinition;

    [Parameter, EditorRequired]
    public required MermaidResult Diagram { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrWhiteSpace(Diagram.Definition))
        {
            _renderFailed = true;
            return;
        }

        if (firstRender)
        {
            try
            {
                _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/GenerativeUI/MermaidDisplay.razor.js");
            }
            catch (JSDisconnectedException)
            {
                return;
            }
            catch (JSException)
            {
                _renderFailed = true;
                StateHasChanged();
                return;
            }
        }

        if (_module is null ||
            _renderFailed ||
            string.Equals(_lastRenderedDefinition, Diagram.Definition, StringComparison.Ordinal))
        {
            return;
        }

        try
        {
            await _module.InvokeVoidAsync("renderDiagram", _canvas, Diagram.Definition, $"mermaid-{Guid.NewGuid():N}");
            _lastRenderedDefinition = Diagram.Definition;
            _renderFailed = false;
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
            _renderFailed = true;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }
}
