@* ChartDisplay: Renders chart data from the show_chart tool as a formatted visualization *@

@using AGUIDojoClient.Models
<div class="chart-display">
    @if (!string.IsNullOrWhiteSpace(Chart.Title))
    {
        <div class="chart-header">
            <LucideIcon Name="bar-chart-3" Size="16" Class="chart-icon" />
            <span class="chart-title">@Chart.Title</span>
            <BbBadge Variant="BadgeVariant.Secondary" Class="chart-type-badge">
                @Chart.ChartType
            </BbBadge>
        </div>
    }

    @if (Chart.ChartType.Equals("pie", StringComparison.OrdinalIgnoreCase))
    {
        @* Pie chart rendered as a proportional list with visual bars *@
        <div class="chart-pie-container">
            @if (Chart.Datasets.Count > 0 && Chart.Labels.Count > 0)
            {
                double total = Chart.Datasets[0].Values.Sum();
                @for (int i = 0; i < Chart.Labels.Count && i < Chart.Datasets[0].Values.Count; i++)
                {
                    double value = Chart.Datasets[0].Values[i];
                    double percentage = total > 0 ? (value / total * 100) : 0;
                    string color = GetSeriesColor(i);

                    <div class="pie-item">
                        <div class="pie-item-header">
                            <span class="pie-color-swatch" style="background-color: @color;"></span>
                            <span class="pie-label">@Chart.Labels[i]</span>
                            <span class="pie-value">@value.ToString("N1")</span>
                            <BbBadge Variant="BadgeVariant.Outline" Class="pie-percentage">
                                @percentage.ToString("F1")%
                            </BbBadge>
                        </div>
                        <div class="pie-bar-track">
                            <div class="pie-bar-fill" style="width: @percentage.ToString("F1")%; background-color: @color;"></div>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        @* Bar / Line / Area chart rendered as a table with visual bar indicators *@
        <div class="chart-table-container">
            <table class="chart-table">
                <thead>
                    <tr>
                        <th class="chart-label-col">Label</th>
                        @foreach (var dataset in Chart.Datasets)
                        {
                            <th class="chart-value-col">
                                <span class="dataset-color-dot" style="background-color: @GetSeriesColor(Chart.Datasets.IndexOf(dataset));"></span>
                                @dataset.Name
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Chart.Labels.Count; i++)
                    {
                        int labelIndex = i;
                        <tr>
                            <td class="chart-label-cell">@Chart.Labels[labelIndex]</td>
                            @foreach (var dataset in Chart.Datasets)
                            {
                                double value = labelIndex < dataset.Values.Count ? dataset.Values[labelIndex] : 0;
                                double maxVal = GetMaxValue();
                                double barWidth = maxVal > 0 ? (value / maxVal * 100) : 0;
                                string color = GetSeriesColor(Chart.Datasets.IndexOf(dataset));

                                <td class="chart-value-cell">
                                    <div class="chart-bar-container">
                                        <div class="chart-bar" style="width: @barWidth.ToString("F1")%; background-color: @color;"></div>
                                        <span class="chart-value-text">@FormatNumber(value)</span>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* Legend *@
    @if (Chart.Datasets.Count > 1)
    {
        <div class="chart-legend">
            @foreach (var dataset in Chart.Datasets)
            {
                string color = GetSeriesColor(Chart.Datasets.IndexOf(dataset));
                <div class="chart-legend-item">
                    <span class="chart-legend-color" style="background-color: @color;"></span>
                    <span class="chart-legend-label">@dataset.Name</span>
                </div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// The chart result to display.
    /// </summary>
    [Parameter, EditorRequired]
    public required ChartResult Chart { get; set; }

    /// <summary>
    /// Color palette for chart series, using theme-friendly colors.
    /// </summary>
    private static readonly string[] s_seriesColors =
    [
        "hsl(221, 83%, 53%)",  // Blue
        "hsl(142, 71%, 45%)",  // Green
        "hsl(38, 92%, 50%)",   // Amber
        "hsl(0, 84%, 60%)",    // Red
        "hsl(262, 83%, 58%)",  // Purple
        "hsl(199, 89%, 48%)",  // Cyan
        "hsl(25, 95%, 53%)",   // Orange
        "hsl(330, 81%, 60%)",  // Pink
    ];

    /// <summary>
    /// Gets the color for a dataset by index, cycling through the palette.
    /// </summary>
    private static string GetSeriesColor(int index)
    {
        return s_seriesColors[index % s_seriesColors.Length];
    }

    /// <summary>
    /// Gets the maximum value across all datasets for bar width scaling.
    /// </summary>
    private double GetMaxValue()
    {
        double max = 0;
        foreach (var dataset in Chart.Datasets)
        {
            foreach (var value in dataset.Values)
            {
                if (value > max)
                {
                    max = value;
                }
            }
        }

        return max;
    }

    /// <summary>
    /// Formats a number for display, using abbreviations for large values.
    /// </summary>
    private static string FormatNumber(double value)
    {
        return value switch
        {
            >= 1_000_000 => $"{value / 1_000_000:F1}M",
            >= 1_000 => $"{value / 1_000:F1}K",
            _ => value.ToString("N1")
        };
    }
}
