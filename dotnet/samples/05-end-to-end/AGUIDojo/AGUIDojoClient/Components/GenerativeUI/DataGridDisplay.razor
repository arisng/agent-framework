@* DataGridDisplay: Renders tabular data from the show_data_grid tool using BB DataTable.
   Features: built-in search, sort, pagination, column visibility toggle, horizontal/vertical scroll.
   Shared State AG-UI feature — renders in the Canvas Pane via session state. *@

@using AGUIDojoClient.Models

<div class="data-grid-display">
    @* Header: title + row count badge *@
    @if (!string.IsNullOrWhiteSpace(DataGrid.Title))
    {
        <div class="data-grid-header">
            <LucideIcon Name="table-2" Size="16" Class="data-grid-icon" />
            <span class="data-grid-title">@DataGrid.Title</span>
            <BbBadge Variant="BadgeVariant.Secondary" Class="data-grid-count">
                @DataGrid.Rows.Count @(DataGrid.Rows.Count == 1 ? "row" : "rows")
            </BbBadge>
        </div>
    }

    @* BB DataTable with built-in toolbar (search + column visibility), pagination, sort *@
    <div class="data-grid-table-wrapper">
        <BbDataTable TData="Dictionary<string, string>"
                   Data="@DataGrid.Rows"
                   ShowToolbar="true"
                   ShowPagination="true"
                   InitialPageSize="10"
                   PageSizes="@(new[] { 5, 10, 20, 50 })"
                   EnableKeyboardNavigation="true"
                   Class="data-grid-datatable">
            <Columns>
                @foreach (var column in DataGrid.Columns)
                {
                    var col = column;
                    @if (col.Equals("Status", StringComparison.OrdinalIgnoreCase))
                    {
                        <BbDataTableColumn TData="Dictionary<string, string>"
                                         TValue="string"
                                         Property="@(row => row.GetValueOrDefault(col, ""))"
                                         Header="@col"
                                         Sortable="true"
                                         Filterable="true">
                            <CellTemplate Context="row">
                                @{
                                    var cellValue = row.GetValueOrDefault(col, "");
                                    if (!string.IsNullOrEmpty(cellValue))
                                    {
                                        <BbBadge Variant="@GetStatusBadgeVariant(cellValue)">@cellValue</BbBadge>
                                    }
                                    else
                                    {
                                        <span class="data-grid-null">—</span>
                                    }
                                }
                            </CellTemplate>
                        </BbDataTableColumn>
                    }
                    else
                    {
                        <BbDataTableColumn TData="Dictionary<string, string>"
                                         TValue="string"
                                         Property="@(row => row.GetValueOrDefault(col, ""))"
                                         Header="@col"
                                         Sortable="true"
                                         Filterable="true" />
                    }
                }
            </Columns>
            <EmptyTemplate>
                <div class="data-grid-empty-state">
                    <LucideIcon Name="inbox" Size="32" Class="data-grid-empty-icon" />
                    <p class="data-grid-empty-text">No data available</p>
                </div>
            </EmptyTemplate>
        </BbDataTable>
    </div>
</div>

@code {
    /// <summary>
    /// The data grid result to display.
    /// </summary>
    [Parameter, EditorRequired]
    public required DataGridResult DataGrid { get; set; }

    /// <summary>
    /// Returns the BB Badge variant for status-like column values.
    /// </summary>
    private static BadgeVariant GetStatusBadgeVariant(string value) => value.ToLowerInvariant() switch
    {
        "shipped" or "delivered" or "completed" or "active" => BadgeVariant.Default,
        "processing" or "in progress" => BadgeVariant.Secondary,
        "pending" or "draft" => BadgeVariant.Outline,
        "cancelled" or "failed" or "rejected" => BadgeVariant.Destructive,
        _ => BadgeVariant.Secondary
    };
}
