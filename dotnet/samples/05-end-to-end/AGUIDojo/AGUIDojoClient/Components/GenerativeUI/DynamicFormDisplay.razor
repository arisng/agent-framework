@* DynamicFormDisplay: Renders a dynamic form from the show_form tool using BlazorBlueprint components *@

@using AGUIDojoClient.Models
@using BlazorBlueprint.Components.Badge
@using BlazorBlueprint.Components.Button
@using BlazorBlueprint.Components.Input
@using BlazorBlueprint.Components.Label
@using BlazorBlueprint.Components.Select
@using BlazorBlueprint.Components.Textarea
@using BlazorBlueprint.Components.Checkbox
@using BlazorBlueprint.Icons.Lucide.Components

<div class="dynamic-form-display">
    @if (!string.IsNullOrWhiteSpace(Form.Title))
    {
        <div class="form-header">
            <LucideIcon Name="clipboard-list" Size="16" Class="form-icon" />
            <span class="form-title">@Form.Title</span>
            <Badge Variant="BadgeVariant.Secondary" Class="form-field-count">
                @Form.Fields.Count @(Form.Fields.Count == 1 ? "field" : "fields")
            </Badge>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Form.Description))
    {
        <p class="form-description">@Form.Description</p>
    }

    <div class="form-fields">
        @foreach (var field in Form.Fields)
        {
            <div class="form-field @(field.Type == "checkbox" ? "form-field-checkbox" : "")">
                @if (field.Type != "checkbox")
                {
                    <Label For="@field.Name" Class="form-label">
                        @field.Label
                        @if (field.Required)
                        {
                            <span class="form-required">*</span>
                        }
                    </Label>
                }

                @switch (field.Type.ToLowerInvariant())
                {
                    case "textarea":
                        <Textarea Id="@field.Name"
                                  Placeholder="@field.Placeholder"
                                  Class="form-textarea"
                                  Value="@(field.DefaultValue ?? string.Empty)" />
                        break;

                    case "select":
                        @if (field.Options is { Count: > 0 })
                        {
                            <select id="@field.Name" class="form-select">
                                <option value="" disabled selected>Select an option...</option>
                                @foreach (var option in field.Options)
                                {
                                    <option value="@option" selected="@(option == field.DefaultValue)">@option</option>
                                }
                            </select>
                        }
                        break;

                    case "checkbox":
                        <div class="form-checkbox-wrapper">
                            <Checkbox Id="@field.Name"
                                      Checked="@(string.Equals(field.DefaultValue, "true", StringComparison.OrdinalIgnoreCase))" />
                            <Label For="@field.Name" Class="form-checkbox-label">
                                @field.Label
                                @if (field.Required)
                                {
                                    <span class="form-required">*</span>
                                }
                            </Label>
                        </div>
                        break;

                    case "number":
                        <Input Type="InputType.Number"
                               Id="@field.Name"
                               Placeholder="@field.Placeholder"
                               Value="@(field.DefaultValue ?? string.Empty)" />
                        break;

                    case "email":
                        <Input Type="InputType.Email"
                               Id="@field.Name"
                               Placeholder="@field.Placeholder"
                               Value="@(field.DefaultValue ?? string.Empty)" />
                        break;

                    default:
                        <Input Type="InputType.Text"
                               Id="@field.Name"
                               Placeholder="@field.Placeholder"
                               Value="@(field.DefaultValue ?? string.Empty)" />
                        break;
                }
            </div>
        }
    </div>

    <div class="form-actions">
        <Button Variant="ButtonVariant.Default" Class="form-submit-button">
            <LucideIcon Name="send" Size="14" />
            @Form.SubmitLabel
        </Button>
    </div>
</div>

@code {
    /// <summary>
    /// The dynamic form result to display.
    /// </summary>
    [Parameter, EditorRequired]
    public required DynamicFormResult Form { get; set; }
}
