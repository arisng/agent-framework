@using AGUIDojoClient.Store.SessionManager
@inject IThemeService ThemeService

<BbSidebar AriaLabel="Chat sessions">
    <BbSidebarHeader>
        <BbSidebarHeaderContent>
            <div class="sidebar-brand-icon">
                <LucideIcon Name="sparkles" Size="20" />
            </div>
            <BbSidebarHeaderInfo>
                <div class="sidebar-brand-copy">
                    <span class="sidebar-brand-title">AG-UI Dojo</span>
                    <span class="sidebar-brand-subtitle">Session workspace</span>
                </div>
            </BbSidebarHeaderInfo>
        </BbSidebarHeaderContent>
    </BbSidebarHeader>

    <BbSidebarContent>
        <BbSidebarGroup>
            <BbSidebarGroupLabel>Sessions</BbSidebarGroupLabel>
            <BbSidebarGroupContent>
                <BbSidebarMenu>
                    @if (Sessions.Count == 0)
                    {
                        <BbSidebarMenuItem>
                            <div class="session-sidebar-empty">No sessions yet. Start a new chat to begin.</div>
                        </BbSidebarMenuItem>
                    }
                    else
                    {
                        @foreach (SessionEntry session in Sessions)
                        {
                            <SessionListItem Entry="@session"
                                             IsActive="@string.Equals(session.Metadata.Id, ActiveSessionId, StringComparison.Ordinal)"
                                             OnSelected="@OnSessionSelected"
                                             OnDeleted="@OnSessionDeleted" />
                        }
                    }
                </BbSidebarMenu>
            </BbSidebarGroupContent>
        </BbSidebarGroup>
    </BbSidebarContent>

    <BbSidebarFooter>
        <BbSidebarMenu Class="sidebar-footer-menu">
            <BbSidebarMenuItem>
                <BbSidebarMenuButton @onclick="HandleNewChatAsync" Tooltip="Start a new conversation">
                    <LucideIcon Name="plus" Size="16" />
                    <span>New Chat</span>
                </BbSidebarMenuButton>
            </BbSidebarMenuItem>
            <BbSidebarMenuItem>
                <BbSidebarMenuButton @onclick="ToggleThemeAsync"
                                     Tooltip="@(_isDark ? "Switch to light theme" : "Switch to dark theme")">
                    @if (_isDark)
                    {
                        <LucideIcon Name="sun" Size="16" />
                        <span>Light Mode</span>
                    }
                    else
                    {
                        <LucideIcon Name="moon" Size="16" />
                        <span>Dark Mode</span>
                    }
                </BbSidebarMenuButton>
            </BbSidebarMenuItem>
        </BbSidebarMenu>
    </BbSidebarFooter>

    <BbSidebarRail />
</BbSidebar>

@code {
    [Parameter]
    public EventCallback OnNewChat { get; set; }

    [Parameter]
    public IReadOnlyList<SessionEntry> Sessions { get; set; } = [];

    [Parameter]
    public string ActiveSessionId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnSessionSelected { get; set; }

    [Parameter]
    public EventCallback<string> OnSessionDeleted { get; set; }

    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string theme = await ThemeService.GetThemeAsync();
            _isDark = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);
            StateHasChanged();
        }
    }

    private Task HandleNewChatAsync() => OnNewChat.InvokeAsync();

    private async Task ToggleThemeAsync()
    {
        string newTheme = await ThemeService.ToggleThemeAsync();
        _isDark = string.Equals(newTheme, "dark", StringComparison.OrdinalIgnoreCase);
    }
}
