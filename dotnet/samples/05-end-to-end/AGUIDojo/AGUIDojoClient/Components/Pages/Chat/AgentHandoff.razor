@using BlazorBlueprint.Components.Separator
@using BlazorBlueprint.Icons.Lucide.Components

@* Renders a separator indicating an agent handoff in the conversation.
   Displays "Switched to {AgentName}" between two horizontal lines when
   the active agent changes during a multi-agent conversation. *@

<div class="agent-handoff-separator">
    <Separator Class="agent-handoff-line" />
    <span class="agent-handoff-label">
        <LucideIcon Name="arrow-right-left" Size="12" />
        <span>Switched to @AgentName</span>
    </span>
    <Separator Class="agent-handoff-line" />
</div>

@code {
    /// <summary>
    /// The name of the agent that is now active after the handoff.
    /// </summary>
    [Parameter, EditorRequired]
    public required string AgentName { get; set; }
}
