@page "/"
@using AGUIDojoClient.Helpers
@using AGUIDojoClient.Store.SessionManager
@inject IAgentStreamingService StreamingService
@inject IRiskAssessmentService RiskAssessmentService
@inject IStateManager StateManager
@inject ViewportService ViewportService
@inject IDispatcher Dispatcher
@inject IState<SessionManagerState> SessionStore
@implements IDisposable

<PageTitle>AG-UI Dojo Chat</PageTitle>

<ChatHeader OnNewChat="@CreateNewSessionAsync"
            Sessions="@OrderedSessions"
            ActiveSessionId="@ActiveSessionId"
            OnSessionSelected="@HandleSessionSelectedAsync"
            OnSessionDeleted="@HandleSessionDeletedAsync" />

<BbSidebarInset>
    <header class="sidebar-inset-header" role="banner">
        <BbSidebarTrigger />
        <BbSeparator Orientation="SeparatorOrientation.Vertical" Class="h-6" />

        <div class="inset-header-session">
            <LucideIcon Name="@GetActiveSessionStatusIcon()" Size="16" Class="@GetActiveSessionStatusIconClass()" />
            <span class="inset-header-title">@GetCurrentSessionTitle()</span>
        </div>

        <BbBadge Variant="@GetSessionStatusVariant()" Class="@GetSessionStatusBadgeCssClass()">
            @if (GetSessionStatusBadgeIcon() is string statusIcon)
            {
                <LucideIcon Name="@statusIcon" Size="12" Class="@GetSessionStatusBadgeIconClass()" />
            }
            <span>@GetSessionStatusLabel()</span>
        </BbBadge>

        @if (ActiveSessionState.HasInteractiveArtifact)
        {
            <BbButton Variant="ButtonVariant.Ghost"
                      Size="ButtonSize.IconSmall"
                      Class="canvas-toggle-btn"
                      OnClick="@(() => _dualPane?.ToggleCanvasPane() ?? Task.CompletedTask)"
                      AriaLabel="@((_dualPane?.IsCanvasPaneHidden ?? false) ? "Show canvas pane" : "Hide canvas pane")">
                <LucideIcon Name="@((_dualPane?.IsCanvasPaneHidden ?? false) ? "panel-right-open" : "panel-right-close")" Size="16" />
            </BbButton>
        }
    </header>

    <main id="main-content" role="main">
    <DualPaneLayout @ref="_dualPane">
        <ContextPaneContent>
            <ContextPane>
                <ChatMessageList Messages="@SessionSelectors.ActiveMessages(SessionStore.Value)"
                                 InProgressMessage="@ActiveSessionState.CurrentResponseMessage"
                                 PendingApproval="@ActiveSessionState.PendingApproval"
                                 OnApprovalDecision="@OnApprovalDecision"
                                 OnEditMessage="@HandleEditAndRegenerateAsync"
                                 RiskLevel="@(ActiveSessionState.PendingApproval is not null ? RiskAssessmentService.AssessRisk(ActiveSessionState.PendingApproval.FunctionName) : RiskLevel.Low)"
                                 IsMobile="@ViewportService.IsMobile">
                    <NoMessagesContent>
                        <div>Ask the assistant a question to start a conversation.</div>
                    </NoMessagesContent>
                </ChatMessageList>
                <div class="chat-container">
                    <ChatSuggestions OnSelected="@AddUserMessageAsync" @ref="@chatSuggestions" />
                    <ChatInput OnSend="@AddUserMessageAsync"
                               IsAgentRunning="@ActiveSessionState.IsRunning"
                               OnPanic="@HandlePanicAsync"
                               @ref="@chatInput" />
                </div>
            </ContextPane>
        </ContextPaneContent>
        <CanvasPaneContent>
            <CanvasPane>
                @* All artifact content is now rendered by CanvasPane's BB Tabs
                infrastructure from session-keyed state — DiffPreview, RecipeEditor, DocumentPreview,
                and DataGrid tabs are dynamically shown/hidden based on the active session.
                See CanvasPane.razor for tab implementation details. *@
            </CanvasPane>
        </CanvasPaneContent>
    </DualPaneLayout>
    </main>
</BbSidebarInset>

@code {
    private const string SystemPrompt = @"
        You are a helpful assistant.
        ";

    private const int ThrottleDelayMs = 100;

    private DualPaneLayout? _dualPane;
    private string? _observedSessionId;

    private SessionEntry ActiveSession => SessionSelectors.GetActiveSession(SessionStore.Value);

    private IReadOnlyList<SessionEntry> OrderedSessions => SessionSelectors.GetOrderedSessions(SessionStore.Value);

    private SessionState ActiveSessionState => ActiveSession.State;

    private SessionMetadata ActiveSessionMetadata => ActiveSession.Metadata;

    private string ActiveSessionId => ActiveSessionMetadata.Id;
    private ChatInput? chatInput;
    private ChatSuggestions? chatSuggestions;
    private DateTime lastStateChangeTime = DateTime.MinValue;
    private bool pendingStateChange;
    private System.Timers.Timer? throttleTimer;

    private string GetCurrentSessionTitle()
    {
        string title = ActiveSessionMetadata.Title?.Trim() ?? string.Empty;
        return string.IsNullOrWhiteSpace(title) ? SessionMetadata.DefaultTitle : title;
    }

    protected override Task OnInitializedAsync()
    {
        StreamingService.SetUiCallbacks(ThrottledStateHasChanged, () => InvokeAsync(StateHasChanged), callback => InvokeAsync(callback));

        EnsureSessionInitialized(ActiveSessionId);
        SyncActiveSessionContext();

        throttleTimer = new System.Timers.Timer(ThrottleDelayMs);
        throttleTimer.AutoReset = false;
        throttleTimer.Elapsed += OnThrottleElapsed;

        SessionStore.StateChanged += OnFluxorStateChanged;
        return Task.CompletedTask;
    }

    private void OnFluxorStateChanged(object? sender, EventArgs e)
    {
        EnsureSessionInitialized(ActiveSessionId);
        SyncActiveSessionContext();
        ThrottledStateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ViewportService.InitializeAsync();
            ViewportService.OnViewportChanged += OnViewportChanged;
        }
    }

    private void OnViewportChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

    private void ThrottledStateHasChanged()
    {
        DateTime now = DateTime.UtcNow;
        if ((now - lastStateChangeTime).TotalMilliseconds >= ThrottleDelayMs)
        {
            lastStateChangeTime = now;
            InvokeAsync(StateHasChanged);
        }
        else
        {
            pendingStateChange = true;
            throttleTimer?.Stop();
            throttleTimer?.Start();
        }
    }

    private void OnThrottleElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        if (pendingStateChange)
        {
            pendingStateChange = false;
            lastStateChangeTime = DateTime.UtcNow;
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task AddUserMessageAsync(ChatMessage userMessage)
    {
        if (!StreamingService.CanQueueResponse(ActiveSessionId))
        {
            Dispatcher.Dispatch(new SessionActions.AddMessageAction(
                ActiveSessionId,
                new ChatMessage(ChatRole.Assistant, "Too many sessions are already streaming. Please wait for one to finish before sending another message.")));
            await chatInput!.FocusAsync();
            return;
        }

        StreamingService.CancelResponse(ActiveSessionId);

        Recipe? recipeState = ActiveSessionState.CurrentRecipe;
        if (recipeState is null && ShouldBootstrapRecipeState(userMessage))
        {
            StateManager.Initialize();
            recipeState = StateManager.CurrentRecipe;
            Dispatcher.Dispatch(new SessionActions.SetRecipeAction(ActiveSessionId, recipeState));
        }

        if (recipeState is not null)
        {
            StateManager.UpdateRecipe(recipeState);
            DataContent stateContent = StateManager.CreateStateContent();
            userMessage.Contents.Add(stateContent);
        }

        Dispatcher.Dispatch(new SessionActions.AddMessageAction(ActiveSessionId, userMessage));
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();

        await StreamingService.ProcessAgentResponseAsync(ActiveSessionId);
        chatSuggestions?.Update(ActiveSessionState.Messages);
    }

    private void OnApprovalDecision(bool approved) => StreamingService.ResolveApproval(ActiveSessionId, approved);

    private async Task HandleEditAndRegenerateAsync((int MessageIndex, string NewText) args)
    {
        if (!StreamingService.CanQueueResponse(ActiveSessionId))
        {
            return;
        }

        StreamingService.CancelResponse(ActiveSessionId);

        Dispatcher.Dispatch(new SessionActions.EditAndRegenerateAction(ActiveSessionId, args.MessageIndex, args.NewText));
        await chatInput!.FocusAsync();

        await StreamingService.ProcessAgentResponseAsync(ActiveSessionId);
    }

    private async Task HandlePanicAsync()
    {
        StreamingService.HandlePanic(ActiveSessionId);
        await chatInput!.FocusAsync();
    }

    private async Task HandleCheckpointRevertAsync(string checkpointId)
    {
        StreamingService.HandleCheckpointRevert(ActiveSessionId, checkpointId);
        await chatInput!.FocusAsync();
    }

    private async Task CreateNewSessionAsync()
    {
        string sessionId = Guid.NewGuid().ToString("N");
        Dispatcher.Dispatch(new SessionActions.CreateSessionAction(sessionId, EndpointPath: SessionMetadata.DefaultEndpointPath));
        EnsureSessionInitialized(sessionId);
        SyncActiveSessionContext();
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();
    }

    private void EnsureSessionInitialized(string sessionId)
    {
        if (!SessionSelectors.TryGetSession(SessionStore.Value, sessionId, out SessionEntry entry))
        {
            return;
        }

        if (entry.State.Messages.Count == 0)
        {
            Dispatcher.Dispatch(new SessionActions.AddMessageAction(sessionId, new ChatMessage(ChatRole.System, SystemPrompt)));
        }

        if (string.Equals(SessionStore.Value.ActiveSessionId, sessionId, StringComparison.Ordinal))
        {
            StreamingService.SyncSessionState(sessionId);
        }
    }

    private async Task HandleSessionSelectedAsync(string sessionId)
    {
        if (SessionSelectors.TryGetSession(SessionStore.Value, sessionId, out SessionEntry entry))
        {
            EnsureSessionInitialized(sessionId);
        }

        await chatInput!.FocusAsync();
    }

    private async Task HandleSessionDeletedAsync(string sessionId)
    {
        if (string.Equals(sessionId, ActiveSessionId, StringComparison.Ordinal))
        {
            EnsureSessionInitialized(ActiveSessionId);
        }

        await chatInput!.FocusAsync();
    }

    private void SyncActiveSessionContext()
    {
        if (string.IsNullOrEmpty(ActiveSessionId))
        {
            return;
        }

        if (string.Equals(_observedSessionId, ActiveSessionId, StringComparison.Ordinal))
        {
            return;
        }

        _observedSessionId = ActiveSessionId;
        StreamingService.SyncSessionState(ActiveSessionId);
    }

    private string GetActiveSessionStatusIcon() => ActiveSessionMetadata.HasPendingApproval
        ? "bell"
        : ActiveSessionMetadata.Status switch
        {
            SessionStatus.Created => "circle",
            SessionStatus.Active => "circle",
            SessionStatus.Streaming => "loader",
            SessionStatus.Background => "loader",
            SessionStatus.Completed => "check",
            SessionStatus.Error => "alert-triangle",
            SessionStatus.Archived => "archive",
            _ => "circle",
        };

    private string GetActiveSessionStatusIconClass() => ActiveSessionMetadata.HasPendingApproval
        ? "inset-header-status-icon inset-header-status-icon--approval"
        : ActiveSessionMetadata.Status switch
        {
            SessionStatus.Created => "inset-header-status-icon inset-header-status-icon--created",
            SessionStatus.Active => "inset-header-status-icon inset-header-status-icon--active",
            SessionStatus.Streaming => "inset-header-status-icon inset-header-status-icon--streaming",
            SessionStatus.Background => "inset-header-status-icon inset-header-status-icon--background",
            SessionStatus.Completed => "inset-header-status-icon inset-header-status-icon--completed",
            SessionStatus.Error => "inset-header-status-icon inset-header-status-icon--error",
            SessionStatus.Archived => "inset-header-status-icon inset-header-status-icon--created",
            _ => "inset-header-status-icon inset-header-status-icon--created",
        };

    private BadgeVariant GetSessionStatusVariant()
    {
        if (ActiveSessionMetadata.HasPendingApproval)
        {
            return BadgeVariant.Destructive;
        }

        if (ActiveSessionState.IsRunning)
        {
            return BadgeVariant.Default;
        }

        return ActiveSessionMetadata.Status switch
        {
            SessionStatus.Created => BadgeVariant.Outline,
            SessionStatus.Error => BadgeVariant.Destructive,
            _ => BadgeVariant.Secondary,
        };
    }

    private string GetSessionStatusLabel()
    {
        if (ActiveSessionMetadata.HasPendingApproval)
        {
            return "Approval Required";
        }

        if (ActiveSessionState.IsRunning)
        {
            return "Generating...";
        }

        return ActiveSessionMetadata.Status switch
        {
            SessionStatus.Created => "New",
            SessionStatus.Error => "Error",
            _ => "Ready",
        };
    }

    private string? GetSessionStatusBadgeIcon()
    {
        if (ActiveSessionMetadata.HasPendingApproval)
        {
            return "bell";
        }

        if (ActiveSessionState.IsRunning)
        {
            return "loader";
        }

        if (ActiveSessionMetadata.Status == SessionStatus.Error)
        {
            return "alert-triangle";
        }

        return null;
    }

    private string GetSessionStatusBadgeCssClass()
    {
        string stateClass = ActiveSessionMetadata.HasPendingApproval
            ? "agent-status-pill--approval"
            : ActiveSessionState.IsRunning
                ? "agent-status-pill--streaming"
                : string.Empty;

        return string.IsNullOrWhiteSpace(stateClass)
            ? "agent-status-pill ml-auto"
            : $"agent-status-pill ml-auto {stateClass}";
    }

    private string GetSessionStatusBadgeIconClass() => ActiveSessionState.IsRunning && !ActiveSessionMetadata.HasPendingApproval
        ? "agent-status-pill__icon agent-status-pill__icon--spinning"
        : "agent-status-pill__icon";

    private static bool ShouldBootstrapRecipeState(ChatMessage userMessage)
    {
        string? text = userMessage.Text;
        if (string.IsNullOrWhiteSpace(text))
        {
            return false;
        }

        string[] recipeKeywords =
        [
            "recipe",
            "ingredients",
            "cook",
            "cooking",
            "meal",
            "dish",
            "bake",
            "kitchen",
            "dinner",
            "lunch",
            "breakfast",
        ];

        return recipeKeywords.Any(keyword => text.Contains(keyword, StringComparison.OrdinalIgnoreCase));
    }

    public void Dispose()
    {
        ViewportService.OnViewportChanged -= OnViewportChanged;
        SessionStore.StateChanged -= OnFluxorStateChanged;
        throttleTimer?.Stop();
        throttleTimer?.Dispose();
    }
}
